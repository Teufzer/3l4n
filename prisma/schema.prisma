// Prisma schema for 3l4n
// Connection URL is configured in prisma.config.ts (Prisma v7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  username             String?        @unique
  name                 String?
  avatar               String?
  bannerUrl            String?
  bio                  String?
  targetWeight         Float?
  startWeight          Float?
  password             String?
  emailVerified        DateTime?
  image                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  role                 Role           @default(USER)
  banned               Boolean        @default(false)
  verified             Boolean        @default(false)
  weightPrivate        Boolean        @default(false)
  accounts             Account[]
  sessions             Session[]
  weightEntries        WeightEntry[]
  posts                Post[]
  reactions            Reaction[]
  comments             Comment[]
  reports              Report[]
  notificationsAsUser  Notification[] @relation("NotifUser")
  notificationsAsActor Notification[] @relation("NotifActor")
  followers            Follow[]        @relation("Followers")
  following            Follow[]        @relation("Following")
  blockedBy            Block[]         @relation("Blocked")
  blocking             Block[]         @relation("Blocker")
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Post {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content         String
  originalContent String?
  imageUrl        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  editedAt        DateTime?
  reactions       Reaction[]
  comments        Comment[]
  reports         Report[]
  notifications   Notification[]
}

model Comment {
  id            String         @id @default(cuid())
  content       String
  createdAt     DateTime       @default(now())
  userId        String
  postId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports       Report[]
  notifications Notification[]
}

model Report {
  id         String   @id @default(cuid())
  reason     String
  createdAt  DateTime @default(now())
  reporterId String
  postId     String?
  commentId  String?
  resolved   Boolean  @default(false)
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([postId, userId, type])
}

model Notification {
  id        String    @id @default(cuid())
  type      NotifType
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  userId    String
  actorId   String
  postId    String?
  commentId String?
  user      User      @relation("NotifUser", fields: [userId], references: [id], onDelete: Cascade)
  actor     User      @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

enum NotifType {
  MENTION
  REACTION
  COMMENT
  FOLLOW
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @default(cuid())
  expiresAt DateTime @default(dbgenerated("NOW() + INTERVAL '24 hours'"))
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReactionType {
  COURAGE
  EN_FEU
  SOLIDAIRE
}
